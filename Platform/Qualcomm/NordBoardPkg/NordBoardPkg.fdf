!else
  INF RuleOverride = DTB Platform/Qualcomm/NordBoardPkg/DeviceTree/DummyDeviceTree.inf
!endif
  INF EmbeddedPkg/Drivers/DtPlatformDxe/DtPlatformDxe.inf

[FV.FvUefiBoot]
!include MinPlatformPkg/Include/Fdf/CommonSpiFvHeaderInfo.fdf
FvNameGuid         = 5F4C1E30-2B7A-4C1D-9E62-0A1B2C3D4E06
FvAlignment        = 16
ERASE_POLARITY     = 1
MEMORY_MAPPED      = TRUE
STICKY_WRITE       = TRUE
LOCK_CAP           = TRUE
LOCK_STATUS        = TRUE
WRITE_STATUS       = TRUE
WRITE_LOCK_CAP     = TRUE
WRITE_LOCK_STATUS  = TRUE
READ_LOCK_CAP      = TRUE
READ_LOCK_STATUS   = TRUE

  INF MdeModulePkg/Core/Dxe/DxeMain.inf

  FILE FV_IMAGE = 5F4C1E30-2B7A-4C1D-9E62-0A1B2C3D4E05 {
    SECTION GUIDED EE4E5898-3914-4259-9D6E-DC7BD79403CF PROCESSING_REQUIRED = TRUE {
      SECTION FV_IMAGE = FvUefiBootUncompressed
    }
  }

