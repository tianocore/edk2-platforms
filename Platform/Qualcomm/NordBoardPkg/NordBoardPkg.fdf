  INF MdeModulePkg/Bus/Pci/NonDiscoverablePciDeviceDxe/NonDiscoverablePciDeviceDxe.inf

  # BDS / UI / Shell
  INF MdeModulePkg/Universal/DisplayEngineDxe/DisplayEngineDxe.inf
