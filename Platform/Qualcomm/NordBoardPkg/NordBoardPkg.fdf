## @file
#  NordBoardPkg FDF (Qualcomm Nord Generic).
#
#  Multi-FV MinPlatform flash layout. The whole FD is loaded by TF-A as the
#  BL33 payload at PcdFlashAreaBaseAddress and entered at offset 0, so the
#  FvPreMemory FV (containing ArmPlatformPkg/Sec) must remain first.
#
#  Copyright (c) Qualcomm Technologies, Inc. and/or its subsidiaries.<BR>
#  SPDX-License-Identifier: BSD-2-Clause-Patent
##

SET gMinPlatformPkgTokenSpaceGuid.PcdFlashAreaBaseAddress = 0xA0200000
SET gMinPlatformPkgTokenSpaceGuid.PcdFlashAreaSize        = 0x00800000

#
# Board-specific flash sizes (Nord uses emulated NV variables, so the NV
# storage sizes describe reserved layout only). Offsets and base addresses are
# derived by the shared FlashMap include below.
#
SET gEfiMdeModulePkgTokenSpaceGuid.PcdFlashNvStorageVariableSize   = 0x0003C000
SET gEfiMdeModulePkgTokenSpaceGuid.PcdFlashNvStorageFtwWorkingSize = 0x00004000

SET gMinPlatformPkgTokenSpaceGuid.PcdFlashFvPreMemorySize          = 0x00080000
SET gMinPlatformPkgTokenSpaceGuid.PcdFlashFvBspPreMemorySize       = 0x00010000
SET gMinPlatformPkgTokenSpaceGuid.PcdFlashFvFspTSize               = 0x00000000
SET gMinPlatformPkgTokenSpaceGuid.PcdFlashFvFspMSize               = 0x00000000
SET gMinPlatformPkgTokenSpaceGuid.PcdFlashFvFspSSize               = 0x00000000
SET gMinPlatformPkgTokenSpaceGuid.PcdFlashFvPostMemorySize         = 0x00040000
SET gMinPlatformPkgTokenSpaceGuid.PcdFlashFvBspSize                = 0x00010000
SET gMinPlatformPkgTokenSpaceGuid.PcdFlashFvUefiBootSize           = 0x00500000
SET gMinPlatformPkgTokenSpaceGuid.PcdFlashFvOsBootSize             = 0x00100000
SET gMinPlatformPkgTokenSpaceGuid.PcdFlashFvSecuritySize           = 0x00010000

!include QualcommMinPlatformPkg/Include/Fdf/FlashMap.fdf.inc

[FD.NordBoardPkg]
BaseAddress   = 0xA0200000|gArmTokenSpaceGuid.PcdFdBaseAddress
Size          = 0x00800000|gArmTokenSpaceGuid.PcdFdSize
ErasePolarity = 1
BlockSize     = 0x00001000
NumBlocks     = 0x800

  # --- START OF FLASH (Offset 0 = SEC reset vector) ---
  gMinPlatformPkgTokenSpaceGuid.PcdFlashFvPreMemoryOffset    | gMinPlatformPkgTokenSpaceGuid.PcdFlashFvPreMemorySize
  gArmTokenSpaceGuid.PcdFvBaseAddress                        | gArmTokenSpaceGuid.PcdFvSize
  FV = FvPreMemory

  gMinPlatformPkgTokenSpaceGuid.PcdFlashFvBspPreMemoryOffset | gMinPlatformPkgTokenSpaceGuid.PcdFlashFvBspPreMemorySize
  FV = FvBspPreMemory

  gMinPlatformPkgTokenSpaceGuid.PcdFlashFvPostMemoryOffset   | gMinPlatformPkgTokenSpaceGuid.PcdFlashFvPostMemorySize
  FV = FvPostMemory

  gMinPlatformPkgTokenSpaceGuid.PcdFlashFvBspOffset          | gMinPlatformPkgTokenSpaceGuid.PcdFlashFvBspSize
  FV = FvBsp

  gMinPlatformPkgTokenSpaceGuid.PcdFlashFvUefiBootOffset     | gMinPlatformPkgTokenSpaceGuid.PcdFlashFvUefiBootSize
  FV = FvUefiBoot

  gMinPlatformPkgTokenSpaceGuid.PcdFlashFvOsBootOffset       | gMinPlatformPkgTokenSpaceGuid.PcdFlashFvOsBootSize
  FV = FvOsBoot

  gMinPlatformPkgTokenSpaceGuid.PcdFlashFvSecurityOffset     | gMinPlatformPkgTokenSpaceGuid.PcdFlashFvSecuritySize
  FV = FvSecurity

  gMinPlatformPkgTokenSpaceGuid.PcdFlashFvAdvancedOffset     | gMinPlatformPkgTokenSpaceGuid.PcdFlashFvAdvancedSize
  FV = FvAdvanced
  # --- END OF FLASH ---

###########################
# Stage 1 (PEI) Firmware Volumes
###########################
[FV.FvPreMemory]
!include MinPlatformPkg/Include/Fdf/CommonSpiFvHeaderInfo.fdf
FvNameGuid         = 5F4C1E30-2B7A-4C1D-9E62-0A1B2C3D4E01
FvAlignment        = 16
ERASE_POLARITY     = 1
MEMORY_MAPPED      = TRUE
STICKY_WRITE       = TRUE
LOCK_CAP           = TRUE
LOCK_STATUS        = TRUE
WRITE_DISABLED_CAP = TRUE
WRITE_ENABLED_CAP  = TRUE
WRITE_STATUS       = TRUE
WRITE_LOCK_CAP     = TRUE
WRITE_LOCK_STATUS  = TRUE
READ_DISABLED_CAP  = TRUE
READ_ENABLED_CAP   = TRUE
READ_STATUS        = TRUE
READ_LOCK_CAP      = TRUE
READ_LOCK_STATUS   = TRUE

  INF ArmPlatformPkg/Sec/Sec.inf
  INF MdeModulePkg/Core/Pei/PeiMain.inf
  INF ArmPlatformPkg/PlatformPei/PlatformPeim.inf
  INF ArmPlatformPkg/MemoryInitPei/MemoryInitPeim.inf
  INF ArmPkg/Drivers/CpuPei/CpuPei.inf
  INF MdeModulePkg/Universal/PCD/Pei/Pcd.inf
  INF MdeModulePkg/Universal/ReportStatusCodeRouter/Pei/ReportStatusCodeRouterPei.inf
  INF MinPlatformPkg/PlatformInit/ReportFv/ReportFvPei.inf
  INF MdeModulePkg/Core/DxeIplPeim/DxeIpl.inf

[FV.FvBspPreMemory]
!include MinPlatformPkg/Include/Fdf/CommonSpiFvHeaderInfo.fdf
FvNameGuid         = 5F4C1E30-2B7A-4C1D-9E62-0A1B2C3D4E02
FvAlignment        = 16
ERASE_POLARITY     = 1
MEMORY_MAPPED      = TRUE
STICKY_WRITE       = TRUE
LOCK_CAP           = TRUE
LOCK_STATUS        = TRUE
WRITE_STATUS       = TRUE
WRITE_LOCK_CAP     = TRUE
WRITE_LOCK_STATUS  = TRUE
READ_LOCK_CAP      = TRUE
READ_LOCK_STATUS   = TRUE

  INF MdeModulePkg/Universal/StatusCodeHandler/Pei/StatusCodeHandlerPei.inf
  INF MinPlatformPkg/PlatformInit/PlatformInitPei/PlatformInitPreMemNonFsp.inf

###########################
# Stage 2 Firmware Volumes
###########################
[FV.FvPostMemory]
!include MinPlatformPkg/Include/Fdf/CommonSpiFvHeaderInfo.fdf
FvNameGuid         = 5F4C1E30-2B7A-4C1D-9E62-0A1B2C3D4E03
FvAlignment        = 16
ERASE_POLARITY     = 1
MEMORY_MAPPED      = TRUE
STICKY_WRITE       = TRUE
LOCK_CAP           = TRUE
LOCK_STATUS        = TRUE
WRITE_STATUS       = TRUE
